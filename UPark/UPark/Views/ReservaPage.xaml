<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.ReservaPage"
             BackgroundColor="#f5f5f5">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False"/>
    </Shell.BackButtonBehavior>
    <Shell.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BackgroundColor="#1565c0" StrokeShape="RoundRectangle 8"
                    Stroke="Transparent" Padding="12,7" Margin="8,0,0,0">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="←" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="Volver" FontSize="13" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNavVolverClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="Reservar Espacio" FontSize="18"
                   FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Cargando -->
            <ActivityIndicator x:Name="LoadingIndicator" IsVisible="True" IsRunning="True"
                               Color="#1565c0" HeightRequest="50"/>

            <!-- Icono -->
            <Border x:Name="IconoPanel" IsVisible="False" BackgroundColor="White"
                    StrokeShape="RoundRectangle 15" Padding="20"
                    HorizontalOptions="Center" WidthRequest="100" HeightRequest="100">
                <Label Text="🅿" FontSize="55"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Detalles del espacio -->
            <Border x:Name="DetallePanel" IsVisible="False" BackgroundColor="White"
                    StrokeShape="RoundRectangle 15" Padding="20">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Detalle de la Reserva" FontSize="17" FontAttributes="Bold"
                           TextColor="#1a237e"/>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Estacionamiento:" TextColor="Gray" FontSize="15"/>
                        <Label x:Name="EstacionamientoLabel" Grid.Column="1"
                               FontAttributes="Bold" TextColor="#1a237e" FontSize="15"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Número de Espacio:" TextColor="Gray" FontSize="15"/>
                        <Label x:Name="NumeroLabel" Grid.Column="1"
                               FontAttributes="Bold" TextColor="#1a237e" FontSize="15"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Estado:" TextColor="Gray" FontSize="15"/>
                        <Label x:Name="EstadoLabel" Grid.Column="1"
                               FontAttributes="Bold" TextColor="#4caf50" FontSize="15"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Error -->
            <Border x:Name="ErrorPanel" IsVisible="False" BackgroundColor="#ffebee"
                    StrokeShape="RoundRectangle 10" Padding="15">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="⚠" FontSize="18" TextColor="#c62828"/>
                    <Label x:Name="ErrorLabel" TextColor="#c62828" FontSize="14"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Botón Confirmar -->
            <Button x:Name="ConfirmarBtn" IsVisible="False"
                    Text="Confirmar Reserva"
                    BackgroundColor="#4caf50"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnConfirmarClicked"/>

            <!-- Botón Cancelar -->
            <Button Text="Cancelar"
                    BackgroundColor="Transparent"
                    TextColor="#1565c0"
                    FontSize="15"
                    CornerRadius="10"
                    HeightRequest="45"
                    BorderColor="#1565c0"
                    BorderWidth="1.5"
                    Clicked="OnCancelarClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
