<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.MiCuentaPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Mi Cuenta" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Foto de perfil -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                <Frame BackgroundColor="#1565c0" CornerRadius="50"
                       WidthRequest="100" HeightRequest="100" Padding="0"
                       HorizontalOptions="Center">
                    <Label Text="👤" FontSize="50"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                <Label Text="Carlos López" FontSize="22" FontAttributes="Bold"
                       TextColor="#1a237e" HorizontalOptions="Center"/>
                <Label Text="20109633" FontSize="15" TextColor="Gray"
                       HorizontalOptions="Center"/>
                <Label Text="Estudiante" FontSize="14" TextColor="Gray"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Opciones de cuenta -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="5" HasShadow="True">
                <VerticalStackLayout Spacing="0">

                    <!-- Estacionamiento favorito -->
                    <Grid Padding="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Estacionamiento Favorito"
                               FontSize="15" VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="IMM Parking" TextColor="Gray" FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="›" FontSize="20" TextColor="Gray"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee" Margin="15,0"/>

                    <!-- Preferencias notificación -->
                    <Grid Padding="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Preferencias de Notificación"
                               FontSize="15" VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Mis Alertas" TextColor="Gray" FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="›" FontSize="20" TextColor="Gray"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee" Margin="15,0"/>

                    <!-- Cambiar contraseña -->
                    <Grid Padding="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Cambiar Contraseña"
                               FontSize="15" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="›" FontSize="20" TextColor="Gray"
                               VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Botón Cerrar Sesión -->
            <Button Text="✓  Cerrar Sesión"
                    BackgroundColor="#455a64"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnCerrarSesionClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>