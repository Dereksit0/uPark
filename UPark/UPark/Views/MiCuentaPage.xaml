<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.MiCuentaPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Mi Perfil" FontSize="18" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <AbsoluteLayout>

        <!-- Contenido principal -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Encabezado de perfil con iniciales -->
                <Border BackgroundColor="#1a237e" StrokeShape="RoundRectangle 20"
                        Padding="20" Margin="0,5,0,0">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Border BackgroundColor="#1565c0" StrokeShape="RoundRectangle 50"
                                WidthRequest="90" HeightRequest="90"
                                HorizontalOptions="Center" Stroke="#90caf9" StrokeThickness="2.5">
                            <Label x:Name="InicialLabel" Text="ES"
                                   FontSize="34" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="NombreLabel" Text="Estudiante" FontSize="20"
                               FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label x:Name="MatriculaLabel" Text="000000" FontSize="14"
                               TextColor="#90caf9" HorizontalOptions="Center"/>
                        <Border BackgroundColor="#1565c0" StrokeShape="RoundRectangle 20"
                                Padding="12,4" HorizontalOptions="Center">
                            <Label Text="Estudiante" FontSize="12" TextColor="White"
                                   FontAttributes="Bold"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Opciones de cuenta -->
                <Label Text="Configuración" FontSize="13" FontAttributes="Bold"
                       TextColor="#9e9e9e" Margin="4,5,0,0"/>

                <Border BackgroundColor="White" StrokeShape="RoundRectangle 15" Padding="5">
                    <VerticalStackLayout Spacing="0">

                        <!-- Estacionamiento favorito -->
                        <Grid Padding="15,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEstacionamientoFavoritoTapped"/>
                            </Grid.GestureRecognizers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#e3f2fd"
                                    StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                    WidthRequest="38" HeightRequest="38">
                                <Label Text="★" FontSize="18" TextColor="#1565c0"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" Spacing="1" VerticalOptions="Center">
                                <Label Text="Estacionamiento Favorito" FontSize="15" TextColor="Black"/>
                                <Label x:Name="FavoritoLabel" Text="Sin favorito"
                                       FontSize="12" TextColor="#9e9e9e"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#bdbdbd"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#f5f5f5" Margin="15,0"/>

                        <!-- Preferencias de notificación -->
                        <Grid Padding="15,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNotificacionesTapped"/>
                            </Grid.GestureRecognizers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#e8f5e9"
                                    StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                    WidthRequest="38" HeightRequest="38">
                                <Label Text="🔔" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" Spacing="1" VerticalOptions="Center">
                                <Label Text="Preferencias de Notificación" FontSize="15" TextColor="Black"/>
                                <Label Text="Gestiona tus alertas" FontSize="12" TextColor="#9e9e9e"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#bdbdbd"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#f5f5f5" Margin="15,0"/>

                        <!-- Cambiar contraseña -->
                        <Grid Padding="15,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCambiarContrasenaTapped"/>
                            </Grid.GestureRecognizers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BackgroundColor="#fff3e0"
                                    StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                    WidthRequest="38" HeightRequest="38">
                                <Label Text="🔑" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" Spacing="1" VerticalOptions="Center">
                                <Label Text="Cambiar Contraseña" FontSize="15" TextColor="Black"/>
                                <Label Text="Actualiza tu contraseña de acceso" FontSize="12" TextColor="#9e9e9e"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#bdbdbd"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Cerrar sesión -->
                <Button Text="Cerrar Sesión"
                        BackgroundColor="Transparent"
                        TextColor="#f44336"
                        FontSize="15"
                        FontAttributes="Bold"
                        BorderColor="#f44336"
                        BorderWidth="1.5"
                        CornerRadius="10"
                        HeightRequest="48"
                        Margin="0,5,0,10"
                        Clicked="OnCerrarSesionClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Overlay de confirmación de logout -->
        <Grid x:Name="LogoutOverlay" IsVisible="False"
              BackgroundColor="#99000000"
              AbsoluteLayout.LayoutBounds="0,0,1,1"
              AbsoluteLayout.LayoutFlags="All">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="28" WidthRequest="310" Stroke="#e0e0e0">
                <VerticalStackLayout Spacing="20">
                    <Border BackgroundColor="#ffebee" StrokeShape="RoundRectangle 50"
                            WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                        <Label Text="⚠" FontSize="30"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Cerrar Sesión" FontSize="20" FontAttributes="Bold"
                           TextColor="#1a237e" HorizontalOptions="Center"/>
                    <Label Text="¿Estás seguro de que deseas cerrar sesión de tu cuenta?"
                           FontSize="14" TextColor="#666"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Text="Cancelar"
                                BackgroundColor="Transparent" TextColor="#1565c0"
                                BorderColor="#1565c0" BorderWidth="1.5"
                                CornerRadius="10" HeightRequest="44"
                                Clicked="OnLogoutCancelar"/>
                        <Button Grid.Column="1" Text="Salir"
                                BackgroundColor="#f44336" TextColor="White"
                                CornerRadius="10" HeightRequest="44"
                                FontAttributes="Bold"
                                Clicked="OnLogoutConfirmar"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </AbsoluteLayout>

</ContentPage>
