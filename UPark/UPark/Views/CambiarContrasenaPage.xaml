<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.CambiarContrasenaPage"
             BackgroundColor="#f5f5f5">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False"/>
    </Shell.BackButtonBehavior>
    <Shell.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BackgroundColor="#1565c0" StrokeShape="RoundRectangle 8"
                    Stroke="Transparent" Padding="12,7" Margin="8,0,0,0">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="←" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="Volver" FontSize="13" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNavVolverClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="Cambiar Contraseña" FontSize="18"
                   FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Banner de éxito -->
            <Border x:Name="SuccessBanner" IsVisible="False"
                    BackgroundColor="#e8f5e9" StrokeShape="RoundRectangle 10" Padding="15,12">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="✓" TextColor="#2e7d32" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Text="Contraseña actualizada correctamente." TextColor="#2e7d32"
                           FontSize="14" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Formulario -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 15" Padding="20">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Ingresa tu contraseña actual y la nueva contraseña."
                           FontSize="13" TextColor="Gray" HorizontalTextAlignment="Center"/>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <!-- Contraseña actual -->
                    <Label Text="Contraseña actual" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#f8f9fa"
                            Stroke="#e0e0e0" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Entry x:Name="ContrasenaActualEntry" Grid.Column="0"
                                   Placeholder="Contraseña actual"
                                   PlaceholderColor="#aaa" TextColor="Black"
                                   IsPassword="True" FontSize="15" Margin="8,0"/>
                            <Border Grid.Column="1" BackgroundColor="#e8eaf6"
                                    StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                    Margin="0,6,8,6" Padding="10,0">
                                <Label x:Name="ToggleActualLabel" Text="VER"
                                       TextColor="#1565c0" FontSize="11" FontAttributes="Bold"
                                       VerticalOptions="Center" WidthRequest="55"
                                       HorizontalTextAlignment="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleActual"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>
                    <Label x:Name="ActualError" IsVisible="False"
                           TextColor="#f44336" FontSize="12" Margin="5,0"/>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <!-- Nueva contraseña -->
                    <Label Text="Nueva contraseña" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#f8f9fa"
                            Stroke="#e0e0e0" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Entry x:Name="NuevaContrasenaEntry" Grid.Column="0"
                                   Placeholder="Nueva contraseña"
                                   PlaceholderColor="#aaa" TextColor="Black"
                                   IsPassword="True" FontSize="15" Margin="8,0"/>
                            <Border Grid.Column="1" BackgroundColor="#e8eaf6"
                                    StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                    Margin="0,6,8,6" Padding="10,0">
                                <Label x:Name="ToggleNuevaLabel" Text="VER"
                                       TextColor="#1565c0" FontSize="11" FontAttributes="Bold"
                                       VerticalOptions="Center" WidthRequest="55"
                                       HorizontalTextAlignment="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnToggleNueva"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Confirmar nueva -->
                    <Label Text="Confirmar nueva contraseña" FontSize="13" TextColor="#555" FontAttributes="Bold"/>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#f8f9fa"
                            Stroke="#e0e0e0" Padding="5">
                        <Entry x:Name="ConfirmarNuevaEntry"
                               Placeholder="Confirmar nueva contraseña"
                               PlaceholderColor="#aaa" TextColor="Black"
                               IsPassword="True" FontSize="15" Margin="8,0"/>
                    </Border>
                    <Label x:Name="NuevaError" IsVisible="False"
                           TextColor="#f44336" FontSize="12" Margin="5,0"/>

                </VerticalStackLayout>
            </Border>

            <!-- Error general -->
            <Border x:Name="ErrorPanel" IsVisible="False"
                    BackgroundColor="#ffebee" StrokeShape="RoundRectangle 10" Padding="14,10">
                <Label x:Name="ErrorLabel" TextColor="#c62828" FontSize="13"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </Border>

            <!-- Botón guardar -->
            <Button x:Name="GuardarBtn"
                    Text="Guardar Cambios"
                    BackgroundColor="#1565c0" TextColor="White"
                    FontSize="16" FontAttributes="Bold"
                    CornerRadius="10" HeightRequest="50"
                    Clicked="OnGuardarClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
