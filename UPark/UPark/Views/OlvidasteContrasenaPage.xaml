<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.OlvidasteContrasenaPage"
             BackgroundColor="#1a237e">

    <Shell.TitleView>
        <Label Text="Recuperar Contraseña" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="uPark" FontSize="36" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>

            <Label Text="Ingresa tu correo institucional y te enviaremos instrucciones para recuperar tu contraseña."
                   TextColor="#90caf9" FontSize="14"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

            <!-- Correo -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Entry x:Name="CorreoEntry"
                       Placeholder="Correo institucional"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       Keyboard="Email"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference CorreoError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                            <Setter Property="TextColor" Value="#c62828"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference CorreoError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="TextColor" Value="Black"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>

            <Label x:Name="CorreoError"
                   Text="⚠ El correo no puede estar vacío"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Botón Enviar -->
            <Button Text="Enviar instrucciones"
                    BackgroundColor="#1565c0"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnEnviarClicked"/>

            <!-- Volver -->
            <Label Text="← Volver al inicio de sesión"
                   TextColor="#90caf9"
                   HorizontalOptions="Center"
                   FontSize="14">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVolverClicked"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>