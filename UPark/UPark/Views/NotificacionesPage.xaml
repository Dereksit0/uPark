<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.NotificacionesPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Notificaciones" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="10">

                <!-- Notificación 1 - Verde -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🔔" FontSize="24"
                               TextColor="#4caf50" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" Spacing="3">
                            <Label Text="Espacio libre en Estacionamiento IMM (Lugar 8)"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1a237e"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Hace 2 min"
                               FontSize="11" TextColor="Gray" VerticalOptions="Start"/>
                    </Grid>
                </Frame>

                <!-- Notificación 2 - Roja -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="⚠️" FontSize="24"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" Spacing="3">
                            <Label Text="Estacionamiento UMAD casi lleno - 2 espacios disponibles"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1a237e"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Hace 10 min"
                               FontSize="11" TextColor="Gray" VerticalOptions="Start"/>
                    </Grid>
                </Frame>

                <!-- Notificación 3 -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🔔" FontSize="24"
                               TextColor="#4caf50" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" Spacing="3">
                            <Label Text="Lugar 15 se ha liberado en IMM"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1a237e"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Hace 30 min"
                               FontSize="11" TextColor="Gray" VerticalOptions="Start"/>
                    </Grid>
                </Frame>

                <!-- Notificación 4 -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="🔔" FontSize="24"
                               TextColor="#4caf50" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" Spacing="3">
                            <Label Text="Espacio disponible en Estacionamiento UMAD"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1a237e"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Hace 1 hora"
                               FontSize="11" TextColor="Gray" VerticalOptions="Start"/>
                    </Grid>
                </Frame>

                <!-- Notificación 5 - Alerta -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="⚠️" FontSize="24"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" Spacing="3">
                            <Label Text="IMM al 90% de ocupación"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1a237e"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Hace 2 horas"
                               FontSize="11" TextColor="Gray" VerticalOptions="Start"/>
                    </Grid>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>