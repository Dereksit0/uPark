<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.NotificacionesPreferenciasPage"
             BackgroundColor="#f5f5f5">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False"/>
    </Shell.BackButtonBehavior>
    <Shell.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BackgroundColor="#1565c0" StrokeShape="RoundRectangle 8"
                    Stroke="Transparent" Padding="12,7" Margin="8,0,0,0">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="←" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="Volver" FontSize="13" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNavVolverClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="Preferencias de Notificación" FontSize="18"
                   FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Activa o desactiva los tipos de notificaciones que deseas recibir."
                   FontSize="14" TextColor="Gray" HorizontalTextAlignment="Center"/>

            <!-- Sección: Disponibilidad -->
            <Label Text="Disponibilidad" FontSize="14" FontAttributes="Bold"
                   TextColor="#1a237e" Margin="4,5,0,0"/>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="5">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="15,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Espacios disponibles" FontSize="15" TextColor="Black"/>
                            <Label Text="Cuando un espacio se libere en tu favorito"
                                   FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch x:Name="SwitchEspacios" Grid.Column="1"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#f0f0f0" Margin="15,0"/>

                    <Grid Padding="15,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Estacionamiento casi lleno" FontSize="15" TextColor="Black"/>
                            <Label Text="Cuando queden menos de 5 espacios"
                                   FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch x:Name="SwitchCasiLleno" Grid.Column="1"
                                VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Sección: Reservaciones -->
            <Label Text="Reservaciones" FontSize="14" FontAttributes="Bold"
                   TextColor="#1a237e" Margin="4,5,0,0"/>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="5">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="15,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Confirmación de reserva" FontSize="15" TextColor="Black"/>
                            <Label Text="Al hacer o cancelar una reservación"
                                   FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch x:Name="SwitchReserva" Grid.Column="1"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#f0f0f0" Margin="15,0"/>

                    <Grid Padding="15,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Recordatorio de reserva" FontSize="15" TextColor="Black"/>
                            <Label Text="30 minutos antes de que tu reserva expire"
                                   FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch x:Name="SwitchRecordatorio" Grid.Column="1"
                                VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Sección: General -->
            <Label Text="General" FontSize="14" FontAttributes="Bold"
                   TextColor="#1a237e" Margin="4,5,0,0"/>

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="5">
                <Grid Padding="15,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Actualizaciones de la app" FontSize="15" TextColor="Black"/>
                        <Label Text="Nuevas funciones y mejoras"
                               FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch x:Name="SwitchActualizaciones" Grid.Column="1"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Botón guardar -->
            <Button Text="Guardar Preferencias"
                    BackgroundColor="#1565c0"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnGuardarClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
