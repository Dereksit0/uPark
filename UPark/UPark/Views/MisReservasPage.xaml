<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.MisReservasPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Mis Reservas" FontSize="18" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <AbsoluteLayout>

    <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing"
                 AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All">
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="15">

                <!-- Cargando -->
                <ActivityIndicator x:Name="LoadingIndicator" IsVisible="True" IsRunning="True"
                                   Color="#1565c0" HeightRequest="60"/>

                <Label Text="Reserva Activa" FontSize="18" FontAttributes="Bold"
                       TextColor="#1a237e"/>

                <!-- Sin reserva activa -->
                <Border x:Name="NoReservaPanel" IsVisible="False" BackgroundColor="White"
                        StrokeShape="RoundRectangle 15" Padding="30">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="📭" FontSize="52" HorizontalOptions="Center"/>
                        <Label Text="No tienes ninguna reserva activa."
                               FontSize="15" TextColor="Gray" HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Ve a Disponibilidad y elige un espacio libre."
                               FontSize="13" TextColor="Gray" HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Ir a Disponibilidad"
                                BackgroundColor="#1565c0" TextColor="White"
                                FontAttributes="Bold" CornerRadius="10"
                                HeightRequest="44" Margin="0,10,0,0"
                                Clicked="OnIrDisponibilidadClicked"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Reserva activa -->
                <Border x:Name="ReservaActivaPanel" IsVisible="False" BackgroundColor="White"
                        StrokeShape="RoundRectangle 15" Padding="20">
                    <VerticalStackLayout Spacing="14">

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🟢" FontSize="24"/>
                            <Label Text="Reserva Activa" FontSize="16" FontAttributes="Bold"
                                   TextColor="#4caf50" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Estacionamiento:" TextColor="Gray" FontSize="14"/>
                            <Label x:Name="EstacionamientoLabel" Grid.Column="1"
                                   FontAttributes="Bold" TextColor="#1a237e" FontSize="14"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Número de Espacio:" TextColor="Gray" FontSize="14"/>
                            <Label x:Name="EspacioLabel" Grid.Column="1"
                                   FontAttributes="Bold" TextColor="#1a237e" FontSize="14"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Fecha / Hora:" TextColor="Gray" FontSize="14"/>
                            <Label x:Name="FechaLabel" Grid.Column="1"
                                   FontAttributes="Bold" TextColor="#1a237e" FontSize="14"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                        <Button x:Name="CancelarBtn"
                                Text="Cancelar Reserva"
                                BackgroundColor="#f44336" TextColor="White"
                                FontAttributes="Bold" CornerRadius="10" HeightRequest="46"
                                Clicked="OnCancelarReservaClicked"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

    <!-- Overlay de confirmación cancelar reserva -->
    <Grid x:Name="CancelarOverlay" IsVisible="False"
          BackgroundColor="#99000000"
          AbsoluteLayout.LayoutBounds="0,0,1,1"
          AbsoluteLayout.LayoutFlags="All">
        <Border BackgroundColor="White" StrokeShape="RoundRectangle 20"
                HorizontalOptions="Center" VerticalOptions="Center"
                Padding="28" WidthRequest="310" Stroke="#e0e0e0">
            <VerticalStackLayout Spacing="18">
                <Border BackgroundColor="#ffebee" StrokeShape="RoundRectangle 50"
                        WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                    <Label Text="🚫" FontSize="30"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Cancelar Reserva" FontSize="20" FontAttributes="Bold"
                       TextColor="#1a237e" HorizontalOptions="Center"/>
                <Label x:Name="CancelarMensaje"
                       Text="¿Deseas cancelar esta reserva? El espacio quedará libre."
                       FontSize="14" TextColor="#666"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Text="No, volver"
                            BackgroundColor="Transparent" TextColor="#1565c0"
                            BorderColor="#1565c0" BorderWidth="1.5"
                            CornerRadius="10" HeightRequest="44"
                            Clicked="OnCancelarOverlayCerrar"/>
                    <Button Grid.Column="1" Text="Sí, cancelar"
                            BackgroundColor="#f44336" TextColor="White"
                            CornerRadius="10" HeightRequest="44"
                            FontAttributes="Bold"
                            Clicked="OnCancelarOverlayConfirmar"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>

    </AbsoluteLayout>

</ContentPage>
