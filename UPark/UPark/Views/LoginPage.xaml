<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.LoginPage"
             BackgroundColor="#1a237e">

    <ContentPage.Resources>
        <Style x:Key="EntryValido" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="TextColor" Value="Black"/>
        </Style>
        <Style x:Key="EntryInvalido" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#ffebee"/>
            <Setter Property="TextColor" Value="#c62828"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Logo -->
            <Border BackgroundColor="#1565c0"
                    StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center"
                    Padding="20" WidthRequest="100" HeightRequest="100">
                <Label Text="P" FontSize="50" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Label Text="uPark" FontSize="36" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>

            <Label Text="Acceso Estudiantes" FontSize="18"
                   TextColor="#90caf9" HorizontalOptions="Center"/>

            <!-- Campo Matrícula con Trigger -->
            <Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="White"
                    Padding="5">
                <Entry x:Name="MatriculaEntry"
                       Placeholder="Matrícula"
                       PlaceholderColor="Gray"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference MatriculaError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference MatriculaError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>

            <!-- Error Matrícula -->
            <Label x:Name="MatriculaError"
                   Text="⚠ La matrícula no puede estar vacía"
                   TextColor="#ff5252"
                   FontSize="12"
                   IsVisible="False"
                   Margin="5,0"/>

            <!-- Campo Contraseña con Trigger -->
            <Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="White"
                    Padding="5">
                <Entry x:Name="ContrasenaEntry"
                       Placeholder="Contraseña"
                       PlaceholderColor="Gray"
                       IsPassword="True"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference ContrasenaError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference ContrasenaError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>

            <!-- Error Contraseña -->
            <Label x:Name="ContrasenaError"
                   Text="⚠ La contraseña no puede estar vacía"
                   TextColor="#ff5252"
                   FontSize="12"
                   IsVisible="False"
                   Margin="5,0"/>

            <!-- Botón Login -->
            <Button Text="Iniciar Sesión"
                    BackgroundColor="#1565c0"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnLoginClicked">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding Source={x:Reference MatriculaError}, Path=IsVisible}"
                                 Value="True">
                        <Setter Property="BackgroundColor" Value="#455a64"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Label Text="¿Olvidaste tu contraseña?"
                   TextColor="#90caf9"
                   HorizontalOptions="Center"
                   FontSize="14"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>