<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.DetalleEspacioPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Detalle del Espacio" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Icono estado -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 15"
                    Padding="20" HorizontalOptions="Center"
                    WidthRequest="120" HeightRequest="120">
                <Label x:Name="IconoLabel" Text="🟢" FontSize="60"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Detalle del espacio -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 15" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Número de Espacio:"
                               FontSize="16" TextColor="Gray"/>
                        <Label x:Name="NumeroLabel" Grid.Column="1" Text="0"
                               FontSize="16" FontAttributes="Bold" TextColor="#1a237e"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Estado:"
                               FontSize="16" TextColor="Gray"/>
                        <Label x:Name="EstadoLabel" Grid.Column="1" Text="Libre"
                               FontSize="16" FontAttributes="Bold" TextColor="#4caf50"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Última Actualización:"
                               FontSize="16" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="Hace 5 minutos"
                               FontSize="14" TextColor="Gray"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Botón volver -->
            <Button Text="← Volver al mapa"
                    BackgroundColor="#1565c0"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnVolverClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>