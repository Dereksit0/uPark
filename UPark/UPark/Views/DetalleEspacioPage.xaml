<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.DetalleEspacioPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="Detalle del Espacio" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Icono estado -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True"
                   HorizontalOptions="Center" WidthRequest="120" HeightRequest="120">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="🚗" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="✓" FontSize="20" TextColor="#4caf50" 
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Detalle del espacio -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="15">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Número de Espacio:" 
                               FontSize="16" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="12" 
                               FontSize="16" FontAttributes="Bold" TextColor="#1a237e"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Estado:" 
                               FontSize="16" TextColor="Gray"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                            <Ellipse Fill="#4caf50" WidthRequest="12" HeightRequest="12" 
                                     VerticalOptions="Center"/>
                            <Label Text="Libre" FontSize="16" FontAttributes="Bold" 
                                   TextColor="#4caf50"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Última Actualización:" 
                               FontSize="16" TextColor="Gray"/>
                        <Label Grid.Column="1" Text="Hace 5 minutos" 
                               FontSize="14" TextColor="Gray"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Lista de espacios -->
            <Frame BackgroundColor="White" CornerRadius="15" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Espacio 5" FontAttributes="Bold" FontSize="15"/>
                        <Label Grid.Column="1" Text="Libre" TextColor="#4caf50" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Espacio 8" FontAttributes="Bold" FontSize="15"/>
                        <Label Grid.Column="1" Text="Ocupado" TextColor="#f44336" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Espacio 12" FontAttributes="Bold" FontSize="15"/>
                        <Label Grid.Column="1" Text="Ocupado" TextColor="#f44336" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="Espacio 15" FontAttributes="Bold" FontSize="15"/>
                        <Label Grid.Column="1" Text="Libre" TextColor="#4caf50" FontAttributes="Bold"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón Recargar -->
            <Button Text="↺  RECARGAR"
                    BackgroundColor="#c62828"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>