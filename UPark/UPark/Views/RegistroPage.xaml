<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.RegistroPage"
             BackgroundColor="#1a237e">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False"/>
    </Shell.BackButtonBehavior>
    <Shell.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BackgroundColor="#1565c0" StrokeShape="RoundRectangle 8"
                    Stroke="Transparent" Padding="12,7" Margin="8,0,0,0">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="←" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="Volver" FontSize="13" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNavVolverClicked"/>
                </Border.GestureRecognizers>
            </Border>
            <Label Grid.Column="1" Text="Crear Cuenta" FontSize="18"
                   FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="uPark" FontSize="36" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Registro de Estudiante" FontSize="16"
                   TextColor="#90caf9" HorizontalOptions="Center"/>

            <!-- Nombre -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Entry x:Name="NombreEntry"
                       Placeholder="Nombre completo"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference NombreError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                            <Setter Property="TextColor" Value="#c62828"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference NombreError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="TextColor" Value="Black"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>
            <Label x:Name="NombreError"
                   Text="⚠ El nombre no puede estar vacío"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Matrícula -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Entry x:Name="MatriculaEntry"
                       Placeholder="Matrícula"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference MatriculaError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                            <Setter Property="TextColor" Value="#c62828"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference MatriculaError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="TextColor" Value="Black"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>
            <Label x:Name="MatriculaError"
                   Text="⚠ La matrícula no puede estar vacía"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Correo -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Entry x:Name="CorreoEntry"
                       Placeholder="Correo institucional"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       Keyboard="Email"
                       FontSize="16"
                       Margin="10,0">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference CorreoError}, Path=IsVisible}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#ffebee"/>
                            <Setter Property="TextColor" Value="#c62828"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding Source={x:Reference CorreoError}, Path=IsVisible}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="White"/>
                            <Setter Property="TextColor" Value="Black"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
            </Border>
            <Label x:Name="CorreoError"
                   Text="⚠ El correo no puede estar vacío"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Contraseña -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Entry x:Name="ContrasenaEntry" Grid.Column="0"
                           Placeholder="Contraseña"
                           PlaceholderColor="Gray" TextColor="Black"
                           IsPassword="True" FontSize="16" Margin="10,0">
                        <Entry.Triggers>
                            <DataTrigger TargetType="Entry"
                                         Binding="{Binding Source={x:Reference ContrasenaError}, Path=IsVisible}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#ffebee"/>
                                <Setter Property="TextColor" Value="#c62828"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Entry"
                                         Binding="{Binding Source={x:Reference ContrasenaError}, Path=IsVisible}"
                                         Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="TextColor" Value="Black"/>
                            </DataTrigger>
                        </Entry.Triggers>
                    </Entry>
                    <Border Grid.Column="1" BackgroundColor="#e8eaf6"
                            StrokeShape="RoundRectangle 6" Stroke="Transparent"
                            Margin="0,6,8,6" Padding="10,0">
                        <Label x:Name="ToggleContrasenaLabel" Text="VER"
                               TextColor="#1565c0" FontSize="11" FontAttributes="Bold"
                               VerticalOptions="Center" WidthRequest="55"
                               HorizontalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnToggleContrasena"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>
            </Border>
            <Label x:Name="ContrasenaError"
                   Text="⚠ La contraseña no puede estar vacía"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Confirmar Contraseña -->
            <Border StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Entry x:Name="ConfirmarContrasenaEntry" Grid.Column="0"
                           Placeholder="Confirmar contraseña"
                           PlaceholderColor="Gray" TextColor="Black"
                           IsPassword="True" FontSize="16" Margin="10,0">
                        <Entry.Triggers>
                            <DataTrigger TargetType="Entry"
                                         Binding="{Binding Source={x:Reference ConfirmarError}, Path=IsVisible}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#ffebee"/>
                                <Setter Property="TextColor" Value="#c62828"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Entry"
                                         Binding="{Binding Source={x:Reference ConfirmarError}, Path=IsVisible}"
                                         Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="TextColor" Value="Black"/>
                            </DataTrigger>
                        </Entry.Triggers>
                    </Entry>
                    <Border Grid.Column="1" BackgroundColor="#e8eaf6"
                            StrokeShape="RoundRectangle 6" Stroke="Transparent"
                            Margin="0,6,8,6" Padding="10,0">
                        <Label x:Name="ToggleConfirmarLabel" Text="VER"
                               TextColor="#1565c0" FontSize="11" FontAttributes="Bold"
                               VerticalOptions="Center" WidthRequest="55"
                               HorizontalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnToggleConfirmar"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>
            </Border>
            <Label x:Name="ConfirmarError"
                   Text="⚠ Las contraseñas no coinciden"
                   TextColor="#ff5252" FontSize="12"
                   IsVisible="False" Margin="5,0"/>

            <!-- Error general de registro -->
            <Border x:Name="RegistroErrorPanel" IsVisible="False"
                    BackgroundColor="#ffebee" StrokeShape="RoundRectangle 8" Padding="12,8">
                <Label x:Name="RegistroErrorLabel" TextColor="#c62828"
                       FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </Border>

            <!-- Botón Registrarse -->
            <Button Text="Crear Cuenta"
                    BackgroundColor="#1565c0"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnCrearCuentaClicked"/>

            <!-- Volver al Login -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="¿Ya tienes cuenta?" TextColor="White" FontSize="14"/>
                <Label Text="Inicia sesión" TextColor="#90caf9"
                       FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVolverLoginClicked"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>