<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.HomePage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label Text="U-PARK" FontSize="20" FontAttributes="Bold"
               TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <RefreshView x:Name="RefreshControl"
                 Refreshing="OnRefreshing">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Label Text="Bienvenido/a" FontSize="16" TextColor="Gray"/>
                <Label Text="Seleccione Estacionamiento" FontSize="24"
                       FontAttributes="Bold" TextColor="#1a237e"/>

                <!-- Card IMM -->
                <Border BackgroundColor="#1a237e" StrokeShape="RoundRectangle 15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Image Source="imm.png" Aspect="AspectFill"/>
                            <BoxView BackgroundColor="#1a237e" Opacity="0.4"/>
                            <Label Text="Frente a la Universidad"
                                   TextColor="White"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,0,15"/>
                        </Grid>

                        <Button Grid.Row="1"
                                Text="✓  Lugares Disponibles"
                                BackgroundColor="#1565c0"
                                TextColor="White"
                                FontSize="14"
                                Margin="10"
                                CornerRadius="8"
                                Clicked="OnIMMClicked"/>
                    </Grid>
                </Border>

                <!-- Card UMAD -->
                <Border BackgroundColor="#b71c1c" StrokeShape="RoundRectangle 15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Image Source="umad.png" Aspect="AspectFill"/>
                            <BoxView BackgroundColor="#b71c1c" Opacity="0.4"/>
                            <Label Text="Detrás de la Universidad"
                                   TextColor="White"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,0,15"/>
                        </Grid>

                        <Button Grid.Row="1"
                                Text="✓  Lugares Disponibles"
                                BackgroundColor="#c62828"
                                TextColor="White"
                                FontSize="14"
                                Margin="10"
                                CornerRadius="8"
                                Clicked="OnUMADClicked"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>