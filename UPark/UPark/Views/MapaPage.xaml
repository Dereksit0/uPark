<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UPark.Views.MapaPage"
             BackgroundColor="#f5f5f5">

    <Shell.TitleView>
        <Label x:Name="TituloEstacionamiento" Text="IMM Parking" FontSize="20"
               FontAttributes="Bold" TextColor="White"
               VerticalOptions="Center" HorizontalOptions="Center"/>
    </Shell.TitleView>

    <RefreshView x:Name="RefreshControl" Refreshing="OnRefreshing">
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="15">

                <!-- Mapa de espacios -->
                <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="15">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Entrada" HorizontalOptions="Center"
                               FontSize="14" TextColor="Gray"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="Center">
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                        </FlexLayout>

                        <FlexLayout Wrap="Wrap" JustifyContent="Center">
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#f44336" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                            <Border BackgroundColor="#4caf50" WidthRequest="30" HeightRequest="30"
                                    StrokeShape="RoundRectangle 5" Margin="2"/>
                        </FlexLayout>

                        <!-- Leyenda -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,10">
                            <HorizontalStackLayout Spacing="5">
                                <Border BackgroundColor="#4caf50" WidthRequest="20" HeightRequest="20"
                                        StrokeShape="RoundRectangle 3"/>
                                <Label Text="Libre" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Border BackgroundColor="#f44336" WidthRequest="20" HeightRequest="20"
                                        StrokeShape="RoundRectangle 3"/>
                                <Label Text="Ocupado" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <Label Text="Salida" HorizontalOptions="Center"
                               FontSize="14" TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Lista de espacios -->
                <Label Text="Lista de Espacios" FontSize="18"
                       FontAttributes="Bold" TextColor="#1a237e"/>

                <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Espacio 5" FontAttributes="Bold" FontSize="15"/>
                            <Label Grid.Column="1" Text="Libre" TextColor="#4caf50" FontAttributes="Bold"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Espacio 8" FontAttributes="Bold" FontSize="15"/>
                            <Label Grid.Column="1" Text="Ocupado" TextColor="#f44336" FontAttributes="Bold"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Espacio 12" FontAttributes="Bold" FontSize="15"/>
                            <Label Grid.Column="1" Text="Ocupado" TextColor="#f44336" FontAttributes="Bold"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Espacio 15" FontAttributes="Bold" FontSize="15"/>
                            <Label Grid.Column="1" Text="Libre" TextColor="#4caf50" FontAttributes="Bold"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#eeeeee"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Text="Espacio 20" FontAttributes="Bold" FontSize="15"/>
                            <Label Grid.Column="1" Text="Ocupado" TextColor="#f44336" FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>